<% layout("/layouts/boilerplate") %>
<div class="row">
    <h1 class="col-8 offset-3">Log-In Here</h1>
    <div class="col-8 offset-3">
<form action="/login" method="post" class="needs-validation" novalidate>

    
<div class="mb-3" >
  <label for="username" class="form-label">Title</label>
<input type="text" name="username" placeholder="" id="username" class="form-control" required>
<div class="valid-feedback">Looks Good</div> 
</div>



<div class="mb-3" >
  <label for="password" class="form-label">Password</label>
<input type="password" name="password" placeholder="" id="password" class="form-control" required>
<div class="valid-feedback">Looks Good</div> 
</div>
<button class="btn btn-success">Sig-up</button>









</form>
</div>
 </div>
    